# Quant Patch v1 - keep target plan at 1.2R
RR_TARGET_REWRITE_ENABLED=True
RR_TARGET_R=1.2
RR_TARGET_MODE=SINGLE_FULL
VPS_SMC_TP1_R=1.2

# Shadow-only core SMC telemetry. Does NOT route core candidates to execution.
VPS_SMC_CORE_SHADOW_ENABLED=true
CORE_SMC_MIN_RR_AT_EMIT=1.0
CORE_SMC_TARGET_R=1.2

# Keep these as hard production safety gates. Do not loosen from this patch.
ML_GATE_FAIL_OPEN=false
ORDERBOOK_BRIDGE_MODE=LIVE_BLOCK
AI_MANAGER_READ_ONLY=true
AI_MANAGER_AUTO_PATCH=false
AI_MANAGER_AUTO_DEPLOY=false
AI_MANAGER_AUTO_TRADE=false
